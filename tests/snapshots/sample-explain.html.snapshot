<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Sample Explain Report</title>
  <meta name="generator" content="/explain">

  <script>
    /* Eager theme application — inline so it runs before stylesheet parse
       and first paint. Deferred external scripts cannot do this. */
    (function () {
      try {
        var s = localStorage.getItem('joesys-skills-report-theme');
        if (s === 'light' || s === 'dark') {
          document.documentElement.setAttribute('data-theme', s);
        }
      } catch (e) { /* localStorage unavailable — system pref applies */ }
    })();
  </script>

  <link rel="stylesheet" href="../../docs/.assets/report-lib/report-base.css">
  <link rel="stylesheet" href="../../docs/.assets/report-lib/prism-light.css" class="prism-light">
  <link rel="stylesheet" href="../../docs/.assets/report-lib/prism-dark.css"  class="prism-dark">

  <script src="../../docs/.assets/report-lib/prism.min.js" defer></script>
  <script src="../../docs/.assets/report-lib/mermaid.min.js" defer></script>
  <script src="../../docs/.assets/report-lib/report-init.js" defer></script>
</head>
